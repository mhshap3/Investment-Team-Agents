# ─── York IE Platform — Environment Variables ────────────────────────────────
# Copy this to server/.env for local development.
# On Railway, set all variables under Settings → Variables.
# NEVER commit the real .env file — it is in .gitignore.

# ─── Required ─────────────────────────────────────────────────────────────────

# Anthropic API key — used ONLY for Gmail MCP fetch (Stage 0)
# The deal screening pipeline (Stage 1 + Stage 3) uses Gemini, not this.
# Generate at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini API key — used for Stage 1 fact extraction (Flash) and Stage 3 scoring (Pro)
# Generate at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AI...

# HTTP Basic Auth credentials protecting the platform
# Use a strong password — this is the only thing guarding the app
PLATFORM_USER=york-ie
PLATFORM_PASS=choose-a-strong-password-here

# Internal cron bypass secret — used so the daily sync can call /api/sync
# without HTTP Basic Auth. Generate with: openssl rand -hex 32
CRON_SECRET=generate-with-openssl-rand-hex-32

# ─── Optional (have sensible defaults) ────────────────────────────────────────

# SQLite DB path — on Railway, mount a persistent volume at /data
# In dev, defaults to ./data/platform.db (created automatically)
DB_PATH=/data/platform.db

# Express server port — Railway injects PORT automatically
PORT=3001

# Node environment
NODE_ENV=production

# Timezone for node-cron — required for 7am ET cron to fire correctly on Railway
TZ=America/New_York

# Allowed CORS origin — set to your Railway public URL after first deploy
CLIENT_ORIGIN=https://your-app.up.railway.app

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info
